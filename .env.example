# FastAPI backend environment variables
# Copy to .env and fill in your values

# asyncpg connection (used by the application)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/line_simu

# psycopg2 connection (used by APScheduler job store)
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/line_simu

# Supabase (used for service operations)
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# NOTE: LINE channel credentials (channel_secret, channel_access_token, etc.)
# are stored per-channel in the line_channels table and managed via the admin panel.
# No global LINE credentials are needed here.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=your@gmail.com
ADMIN_EMAIL=admin@example.com